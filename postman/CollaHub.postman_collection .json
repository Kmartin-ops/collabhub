{
  "info": {
    "name": "CollabHub API",
    "_postman_id": "collabhub-devflow-collection",
    "description": "Full regression suite for CollabHub backend \u2014 Auth, Users, Projects, Tasks, Health.\n\nUsage:\n1. Import both this collection and the environment file.\n2. Select 'CollabHub \u2014 Local' environment.\n3. Run the 'Auth' folder first \u2014 it auto-saves tokens.\n4. Run the Collection Runner for full regression.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "managerEmail",
      "value": "alice@collabhub.com",
      "type": "string"
    },
    {
      "key": "managerPass",
      "value": "Password123!",
      "type": "string"
    },
    {
      "key": "devEmail",
      "value": "bob@collabhub.com",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const url = pm.request.url.toString();",
          "if (url.includes(\"/auth/login\") || url.includes(\"/auth/register\") || url.includes(\"/auth/refresh\") || url.includes(\"/health\") || url.includes(\"/info\")) {",
          "    return;",
          "}",
          "",
          "const fromCollection = pm.collectionVariables.get(\"accessToken\");",
          "const fromEnv = pm.environment.get(\"accessToken\");",
          "const fromGlobal = pm.globals.get(\"accessToken\");",
          "console.log(\"PRE-REQUEST TOKEN CHECK for:\", url);",
          "console.log(\"  collectionVar:\", fromCollection ? fromCollection.substring(0,20)+\"...\" : \"EMPTY\");",
          "console.log(\"  environment:\",   fromEnv        ? fromEnv.substring(0,20)+\"...\"        : \"EMPTY\");",
          "console.log(\"  globals:\",       fromGlobal     ? fromGlobal.substring(0,20)+\"...\"     : \"EMPTY\");",
          "",
          "const token = fromCollection || fromEnv || fromGlobal;",
          "if (token) {",
          "    pm.request.headers.upsert({ key: \"Authorization\", value: \"Bearer \" + token });",
          "    console.log(\"  Authorization header set \u2705\");",
          "} else {",
          "    console.log(\"  WARNING: No token found \u2014 request will be 401\");",
          "}"
        ]
      }
    }
  ],
  "item": [
