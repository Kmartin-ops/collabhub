              "raw": "{\n  \"email\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPass}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "const token = body.accessToken || body.token;",
                  "",
                  "pm.test(\"Saves tokens to environment\", () => {",
                  "    pm.expect(token).to.be.a(\"string\").and.not.empty;",
                  "    pm.expect(body).to.have.property(\"refreshToken\");",
                  "    // Save to all scopes",
                  "    pm.collectionVariables.set(\"accessToken\", token);",
                  "    pm.collectionVariables.set(\"refreshToken\", body.refreshToken);",
                  "    pm.environment.set(\"accessToken\", token);",
                  "    pm.environment.set(\"refreshToken\", body.refreshToken);",
                  "    pm.globals.set(\"accessToken\", token);",
                  "    pm.globals.set(\"refreshToken\", body.refreshToken);",
                  "});",
                  "pm.test(\"Response time under 1000ms\", () => pm.expect(pm.response.responseTime).to.be.below(1000));"
                ]
              }
            }
          ]
        },
