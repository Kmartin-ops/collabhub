<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Spring constructor injection — mutable object exposure is
         intentional and managed by the Spring container -->
    <Match>
        <Bug category="MALICIOUS_CODE"/>
    </Match>
    <!-- LocalStorageService constructor creates directories -->
    <Match>
        <Class name="com.collabhub.service.LocalStorageService"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>